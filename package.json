{
  "name": "ai-one-person-company-survival-map",
  "private": false,
  "version": "0.0.0",
  "license": "MIT",
  "description": "AI 一人公司生存地图与个人生存体检报告",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && vite build --config vite.github.config.ts",
    "build:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^22.19.19",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.26",
    "oxlint": "^1.71.0",
    "react-server-dom-webpack": "^19.2.6",
    "typescript": "^5.9.3",
    "vinext": "^0.0.50",
    "vite": "^8.1.1",
    "wrangler": "^4.92.0"
  }
}
